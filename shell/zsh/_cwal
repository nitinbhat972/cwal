_cwal_get_themes() {
    local -a themes
    local -a search_dirs
    
    search_dirs=(
        "${XDG_CONFIG_HOME:-$HOME/.config}/cwal/themes"
        "${XDG_DATA_HOME:-$HOME/.local/share}/cwal/themes"
    )
    
    local xdg_dirs="${XDG_DATA_DIRS:-/usr/local/share:/usr/share}"
    for dir in ${(s.:.)xdg_dirs}; do
        search_dirs+=("$dir/cwal/themes")
    done

    for base_dir in $search_dirs; do
        for mode_dir in "dark" "light"; do
            local dir="$base_dir/$mode_dir"
            if [[ -d $dir ]]; then
                themes+=($(ls $dir | sed 's/\.cwal$//'))
            fi
        done
    done
    
    themes+=(random_dark random_light random_all)
    _describe 'theme' themes
}

_cwal_get_backends() {
    local -a backends
    backends=(cwal libimagequant)
    
    local backend_dir="${XDG_CONFIG_HOME:-$HOME/.config}/cwal/backends"
    if [[ -d $backend_dir ]]; then
        backends+=($(ls $backend_dir | sed 's/\.lua$//'))
    fi
    _describe 'backend' backends
}

